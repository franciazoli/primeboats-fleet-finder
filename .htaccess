Options -Indexes
RewriteEngine On

# Block access to sensitive files
<FilesMatch "\.(sql|env)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# PHP API – pass through, no rewrite
RewriteRule ^api/ - [L]

# If the exact file exists inside dist/ – serve it (JS, CSS, images, etc.)
RewriteCond %{DOCUMENT_ROOT}/dist/$1 -f
RewriteRule ^(.+)$ dist/$1 [L]

# Everything else – SPA fallback
RewriteRule ^ dist/index.html [L]
